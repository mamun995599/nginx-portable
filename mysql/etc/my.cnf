[client]
socket = /data/data/com.termux/files/home/nginx-portable/mysql/run/mysqld.sock
port = 3306
default-character-set = utf8mb4

[mysqld]
# User (not needed in Termux but good practice)
user = root

# Directories
basedir = /data/data/com.termux/files/home/nginx-portable/mysql
datadir = /data/data/com.termux/files/home/nginx-portable/mysql/data
tmpdir = /data/data/com.termux/files/home/nginx-portable/mysql/tmp
plugin_dir = /data/data/com.termux/files/home/nginx-portable/mysql/lib/plugin

# Socket and PID
socket = /data/data/com.termux/files/home/nginx-portable/mysql/run/mysqld.sock
pid-file = /data/data/com.termux/files/home/nginx-portable/mysql/run/mysqld.pid

# Logging
log-error = /data/data/com.termux/files/home/nginx-portable/mysql/log/error.log
general_log_file = /data/data/com.termux/files/home/nginx-portable/mysql/log/general.log
slow_query_log_file = /data/data/com.termux/files/home/nginx-portable/mysql/log/slow.log

# Network
port = 3306
bind-address = 127.0.0.1
skip-networking = 0

# Character set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# InnoDB settings
innodb_buffer_pool_size = 64M
innodb_log_file_size = 16M
innodb_flush_log_at_trx_commit = 2
innodb_file_per_table = 1

# Performance
max_connections = 50
max_allowed_packet = 64M
table_open_cache = 64
sort_buffer_size = 512K
read_buffer_size = 256K
read_rnd_buffer_size = 512K
thread_cache_size = 8
query_cache_size = 0
query_cache_type = 0

# MyISAM
key_buffer_size = 16M
myisam_sort_buffer_size = 8M

# Timeout
wait_timeout = 600
interactive_timeout = 600

# Disable performance schema (saves memory)
performance_schema = OFF

[mysqldump]
quick
max_allowed_packet = 64M
default-character-set = utf8mb4

[mysql]
no-auto-rehash
default-character-set = utf8mb4
socket = /data/data/com.termux/files/home/nginx-portable/mysql/run/mysqld.sock

[mysqladmin]
socket = /data/data/com.termux/files/home/nginx-portable/mysql/run/mysqld.sock
